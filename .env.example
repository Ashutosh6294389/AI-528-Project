# ---------------------------------------------------------------------------
# YouTube API
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=your-youtube-api-key

# ---------------------------------------------------------------------------
# Kafka
# Local defaults work for laptop development.
# For Confluent Cloud, replace with the broker host:port and SASL creds.
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=youtube-data
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_STARTING_OFFSETS=latest

# For local Spark use checked-in jars. For managed/cloud Spark set false so
# Maven coordinates are used instead.
KAFKA_SPARK_USE_LOCAL_JARS=true

# ---------------------------------------------------------------------------
# MongoDB
# Local single-node default:
# MONGO_URI=mongodb://localhost:27017
#
# Local 3-node replica set example:
# MONGO_URI=mongodb://mongo1:27017,mongo2:27017,mongo3:27017/?replicaSet=rs0
#
# Atlas example:
# MONGO_URI=mongodb+srv://username:password@cluster-name.xxxxx.mongodb.net/?retryWrites=true&w=majority
# ---------------------------------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=youtube_analytics
BRONZE_TTL_DAYS=30

# ---------------------------------------------------------------------------
# Spark runtime
# Leave SPARK_MASTER unset on Databricks / managed Spark.
# ---------------------------------------------------------------------------
SPARK_RUNTIME=local
SPARK_MASTER=local[*]
